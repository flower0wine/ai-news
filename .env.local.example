# AI News Lambda - Local Development Configuration
# 
# 使用方法: 
# 1. 复制此文件为 .env.local
# 2. 填写你的 API Keys
# 3. 运行: python lambda_function.py

# ========== 必需的配置 ==========
DEEPSEEK_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek/deepseek-chat
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=your-sender-email@example.com
EMAIL_TO=your-recipient-email@example.com

# ========== 可选配置 ==========
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
API_REQUEST_TIMEOUT=30
IS_LOCAL=true
